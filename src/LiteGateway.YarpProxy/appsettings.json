{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "None",
      "Microsoft.Hosting.Lifetime": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "catch-all": {
        "ClusterId": "upstream",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "upstream": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5000"
          }
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 4096,
          "EnableMultipleHttp2Connections": true
        }
      }
    }
  }
}
