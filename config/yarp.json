{
  "ReverseProxy": {
    "Routes": {
      "catch-all": {
        "ClusterId": "upstream",
        "Match": {
          "Path": "{**catch-all}"
        },
        "Transforms": [
          { "RequestHeader": "X-Custom-Header", "Set": "my-value" }
        ]
      }
    },
    "Clusters": {
      "upstream": {
        "Destinations": {
          "default": {
            "Address": "http://backend:3000"
          }
        }
      }
    }
  }
}
